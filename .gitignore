!data/jv_cache/model_lgbm.json
!data/jv_cache/model_lgbm_meta.json
# 例外: 集計済特徴量 + 馬マスタも乗せる (rankings / UI から参照)
!data/jv_cache/features.json
!data/jv_cache/horse_master.json

